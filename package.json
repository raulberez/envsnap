{
  "name": "envsnap",
  "version": "0.1.0",
  "description": "CLI tool to snapshot, diff, and restore environment variable sets across projects",
  "main": "src/index.js",
  "bin": {
    "envsnap": "./bin/envsnap.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "env",
    "environment",
    "variables",
    "snapshot",
    "cli",
    "dotenv"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
